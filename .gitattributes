# --- Git LFS Binary Files ---
# These are large or non-diffable files that should be handled by LFS

*.jar filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text

# Note: Many of your .html files appear to be full game builds (Eaglercraft versions).
# These are often multi-megabyte files that benefit from LFS.
*.html filter=lfs diff=lfs merge=lfs -text

# --- Standard Text Files ---
# These should be handled by Git's normal version control

*.js text
*.txt text
*.md text
*.json text
*.gradle text
*.java text
*.bat text
*.sh text
*.properties text
*.gitignore text
*.gitattributes text
LICENSE text

# --- Specialized Logic ---
# Ensure minified libraries aren't treated as standard diffable text to save CPU
*.min.js -diff
# Keep launcher source pages as normal text (NOT LFS pointers)
index.html -filter -diff -merge text
pages/*.html -filter -diff -merge text
